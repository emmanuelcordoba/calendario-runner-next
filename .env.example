# Base URL de la app (para links en emails)
NEXTAUTH_URL=http://localhost:3000

# Clave secreta para Auth.js (generá una con: openssl rand -base64 32)
AUTH_SECRET=tu-clave-secreta-aqui

# Base de datos — LOCAL (SQLite en archivo, sin cuenta Turso)
TURSO_DATABASE_URL=file:./local.db
TURSO_AUTH_TOKEN=

# En Producción (Vercel) reemplazar por:
# TURSO_DATABASE_URL=libsql://tu-base.turso.io
# TURSO_AUTH_TOKEN=tu-token

# Resend (emails gratuito - 3000/mes)
# Registrate en: https://resend.com/
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=Calendario Runner <noreply@tudominio.com>

# Registro público habilitado (true/false)
REGISTRATION_ENABLED=false
NEXT_PUBLIC_REGISTRATION_ENABLED=false
